{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://calcfleet.com/vcc/schema/dataset-manifest/v0.2.json",
  "title": "VCC Dataset Manifest (v0.2)",
  "description": "Portable JSON Schema (Draft 2020-12) for the Dataset Manifest committed at registry/datasets/<name>/<version>.json. Mirrors the shipped `VccDatasetManifest` shape in spec/dataset-manifest.md (the ai-pricing real example is the normative minimum). Required fields are the 7 that ship today; the v0.3-track lifecycle/provenance fields (publisher, transformation, cadence, deprecatedAt, replacedBy) are additive and optional. additionalProperties:false throughout. Patterns reuse SHA256_HEX, the ISSUED_AT-shaped timestamp, and the safe-https URL rule from CONTRACT §3.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "digest",
    "mediaType",
    "sources",
    "retrievedAt",
    "effectiveFrom",
    "effectiveTo",
    "license"
  ],
  "$defs": {
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "const": "sha-256" },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "safeHttpsUrl": {
      "$comment": "CONTRACT §3: full isSafeHttpsUrl enforced at runtime; here format:uri + https:// prefix.",
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "utcTimestamp": {
      "$comment": "CONTRACT §4 / ISSUED_AT_RE shape. Full calendar validity enforced at runtime.",
      "type": "string",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "allOf": [{ "$ref": "#/$defs/safeHttpsUrl" }, { "maxLength": 200 }]
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 100 }
      }
    }
  },
  "properties": {
    "id": {
      "$comment": "urn:vcc:dataset:<name>.",
      "type": "string",
      "pattern": "^urn:vcc:dataset:[a-z0-9-]+$"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "version": {
      "$comment": "Vintage-style version, e.g. '2026-07' or '2026-Q1'. A content change requires a bump (CI gate).",
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "digest": { "$ref": "#/$defs/digest" },
    "mediaType": { "type": "string", "minLength": 3, "maxLength": 100 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string", "minLength": 1, "maxLength": 200 },
          "url": {
            "allOf": [{ "$ref": "#/$defs/safeHttpsUrl" }, { "maxLength": 500 }]
          }
        }
      }
    },
    "retrievedAt": { "$ref": "#/$defs/utcTimestamp" },
    "effectiveFrom": { "$ref": "#/$defs/utcTimestamp" },
    "effectiveTo": {
      "$comment": "null = current/open-ended snapshot.",
      "oneOf": [{ "$ref": "#/$defs/utcTimestamp" }, { "type": "null" }]
    },
    "license": {
      "$comment": "SPDX id / free label, or null (must be populated per source terms before public serving — dataset-manifest.md §4).",
      "oneOf": [
        { "type": "string", "minLength": 1, "maxLength": 100 },
        { "type": "null" }
      ]
    },
    "publisher": {
      "$comment": "v0.3-track additive (dataset-manifest.md §3 Publisher).",
      "$ref": "#/$defs/publisher"
    },
    "transformation": {
      "$comment": "v0.3-track additive (dataset-manifest.md §4.1): prose steps or ingestion recipe.",
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "cadence": {
      "$comment": "v0.3-track additive (dataset-manifest.md §4.2).",
      "enum": ["monthly", "quarterly", "annual", "irregular"]
    },
    "deprecatedAt": {
      "$comment": "v0.3-track additive (dataset-manifest.md §4.3): null while current.",
      "oneOf": [{ "$ref": "#/$defs/utcTimestamp" }, { "type": "null" }]
    },
    "replacedBy": {
      "$comment": "v0.3-track additive (dataset-manifest.md §4.3): successor id@version, or null.",
      "oneOf": [
        { "type": "string", "minLength": 1, "maxLength": 200 },
        { "type": "null" }
      ]
    }
  }
}
