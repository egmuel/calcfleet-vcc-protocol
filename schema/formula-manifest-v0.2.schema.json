{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://calcfleet.com/vcc/schema/formula-manifest/v0.2.json",
  "title": "VCC Formula Package Manifest (v0.2)",
  "description": "Portable JSON Schema (Draft 2020-12) for the Formula Package Manifest served at /vcc/registry/{slug}/{version}. Mirrors the shipped `VccFormulaManifest` shape described in spec/formula-package.md and spec/formula-authoring.md. The manifest is a formula's identity document; a statement's formula.digest = SHA-256 of JCS(manifest minus its own digest). additionalProperties:false throughout. Patterns/consts reuse SLUG_RE, SEMVER_RE, SHA256_HEX, UNIT_RE and the safe-https URL rule from CONTRACT §3.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "version",
    "entrypoint",
    "inputSchemaDigest",
    "outputSchemaDigest",
    "implementationDigest",
    "testsDigest",
    "dependencies",
    "datasets",
    "sources",
    "numericProfile",
    "numericDictionary",
    "outputProjection"
  ],
  "$defs": {
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "const": "sha-256" },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "safeHttpsUrl": {
      "$comment": "CONTRACT §3: full isSafeHttpsUrl enforced at runtime; here format:uri + https:// prefix.",
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "identifierKey": { "pattern": "^[A-Za-z][A-Za-z0-9_]{0,63}$" },
    "numericDictEntry": {
      "$comment": "A numeric-dictionary entry declares how an input/output key is typed. type from numericKindSchema, scale 0..12, unit optional (UNIT_RE).",
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "scale"],
      "properties": {
        "type": {
          "enum": ["integer", "decimal", "percent", "ratio", "money", "duration"]
        },
        "scale": { "type": "integer", "minimum": 0, "maximum": 12 },
        "unit": {
          "type": "string",
          "pattern": "^[%A-Za-z][%A-Za-z0-9/·°²³-]{0,15}$"
        }
      }
    }
  },
  "properties": {
    "id": {
      "$comment": "urn:vcc:formula:<slug>. Cross-field: id === 'urn:vcc:formula:' + slug (enforced by the registry build/gate, not expressible in pure JSON Schema).",
      "type": "string",
      "pattern": "^urn:vcc:formula:[a-z0-9-]+$"
    },
    "slug": {
      "type": "string",
      "maxLength": 80,
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "entrypoint": {
      "$comment": "Module path + exported function, e.g. src/tools/personal-loan/calc.ts#calcPersonalLoan.",
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "inputSchemaDigest": { "$ref": "#/$defs/digest" },
    "outputSchemaDigest": { "$ref": "#/$defs/digest" },
    "implementationDigest": { "$ref": "#/$defs/digest" },
    "testsDigest": { "$ref": "#/$defs/digest" },
    "dependencies": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 214 },
          "version": { "type": "string", "minLength": 1, "maxLength": 100 }
        }
      }
    },
    "datasets": {
      "$comment": "Dataset manifest ids consumed by this formula (urn:vcc:dataset:<name>). Empty for pilots.",
      "type": "array",
      "maxItems": 16,
      "items": { "type": "string", "pattern": "^urn:vcc:dataset:[a-z0-9-]+$" }
    },
    "sources": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string", "minLength": 1, "maxLength": 200 },
          "url": {
            "allOf": [{ "$ref": "#/$defs/safeHttpsUrl" }, { "maxLength": 500 }]
          }
        }
      }
    },
    "numericProfile": { "const": "vcc-decimal-v1" },
    "numericDictionary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputs", "outputs"],
      "properties": {
        "inputs": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/identifierKey" },
          "additionalProperties": { "$ref": "#/$defs/numericDictEntry" }
        },
        "outputs": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/identifierKey" },
          "additionalProperties": { "$ref": "#/$defs/numericDictEntry" }
        }
      }
    },
    "outputProjection": {
      "$comment": "Top-level output keys that go into certificates (declared + digested). Non-empty for formulas that emit outputs.",
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,63}$" }
    },
    "registry": {
      "$comment": "Optional self-referential registry URL (spec/formula-package.md §2). Kept optional/additive.",
      "allOf": [{ "$ref": "#/$defs/safeHttpsUrl" }, { "maxLength": 400 }]
    },
    "runtimeProfile": {
      "$comment": "Optional self-declared runtime profile (statement engine.runtimeProfile floor; spec/formula-package.md §4.2).",
      "const": "node-deterministic-v1"
    },
    "license": {
      "$comment": "Optional SPDX license id (additive, spec/formula-package.md §4.4).",
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    }
  }
}
