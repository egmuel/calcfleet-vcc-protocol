{
  "name": "@calcfleet/vcc-verifier",
  "version": "0.2.0",
  "description": "Standalone, offline VCC v0.2 L1 verifier (TypeScript). Verifies a Verifiable Calculation Certificate receipt with the published issuer keyset, with no network calls and no dependency on CalcFleet site code.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "conformance": "tsc && node dist/conformance-runner.js"
  },
  "keywords": [
    "vcc",
    "verifiable-calculation-certificate",
    "dsse",
    "ed25519",
    "rfc8785",
    "jcs",
    "verifier",
    "offline"
  ],
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
